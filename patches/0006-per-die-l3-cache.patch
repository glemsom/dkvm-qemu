+    DEFINE_PROP_UINT8("l3-cache-assoc-die0", X86CPU, l3_cache_assoc_die[0], 0),
+    DEFINE_PROP_UINT8("l3-cache-assoc-die1", X86CPU, l3_cache_assoc_die[1], 0),
+    DEFINE_PROP_UINT8("l3-cache-assoc-die2", X86CPU, l3_cache_assoc_die[2], 0),
